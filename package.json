{
  "name": "qualorahub-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "api:pull": "curl -s http://127.0.0.1:3300/api/docs-json -o docs/api/openapi.json",
    "api:generate": "openapi-typescript docs/api/openapi.json -o src/api/generated/schema.ts",
    "api:sync": "npm run api:pull && npm run api:generate",
    "i18n:sync": "node scripts/i18n/sync-web-locales.mjs",
    "api:verify": "node scripts/api/verify-openapi-responses.mjs",
    "check:boundaries": "node scripts/ci/check-import-boundaries.mjs",
    "docs:code-map": "node scripts/docs/generate-code-map.mjs",
    "docs:check": "node scripts/ci/check-docs.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src scripts index.ts App.tsx jest.config.cjs eslint.config.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --coverage",
    "test:contracts": "npm run api:verify && node scripts/ci/run-contract-suite.mjs",
    "test:smoke": "node scripts/ci/run-smoke-suite.mjs",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@tanstack/react-query": "^5.90.21",
    "@turf/area": "^7.3.4",
    "@turf/boolean-intersects": "^7.3.4",
    "@turf/boolean-within": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "expo": "~55.0.4",
    "expo-constants": "~55.0.7",
    "expo-linking": "~55.0.7",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-maps": "1.26.20",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.3",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.7",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
